<Window
    x:Class="FastNote.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    mc:Ignorable="d"
    Title="Untitled - Notepad"
    Width="1100"
    Height="700"
    MinWidth="480"
    MinHeight="320"
    WindowStyle="None"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    AllowDrop="True"
    Drop="Window_OnDrop"
    DragOver="Window_OnDragOver"
    StateChanged="Window_OnStateChanged"
>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource WindowBackgroundBrush}">
            <DockPanel LastChildFill="True">
                <Border x:Name="TopChrome" DockPanel.Dock="Top" Background="{DynamicResource ChromeBrush}">
                    <StackPanel>
                        <Grid x:Name="TitleBar" Height="40" Background="Transparent" PreviewMouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="AppIconHost" Grid.Column="0" Width="28" Height="28" Margin="10,0,8,0" VerticalAlignment="Center" Background="{DynamicResource AppIconBackgroundBrush}" CornerRadius="4">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                            </Border>
                            <Button x:Name="TabScrollLeftButton" Grid.Column="1" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Bottom" Background="Transparent" BorderBrush="Transparent" Padding="0" Click="TabScrollLeftButton_OnClick" ToolTip="Scroll tabs left">
                                <Border x:Name="TabScrollLeftSurface" Width="28" Height="28" CornerRadius="8" Background="{DynamicResource TabInactiveBrush}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                                </Border>
                            </Button>
                            <ScrollViewer x:Name="TabStripScrollViewer" Grid.Column="2" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" CanContentScroll="False" VerticalAlignment="Bottom" Background="Transparent" PanningMode="HorizontalOnly">
                                <StackPanel x:Name="TabStripPanel" Orientation="Horizontal" />
                            </ScrollViewer>
                            <Button x:Name="TabScrollRightButton" Grid.Column="3" Width="28" Height="28" Margin="6,0,6,0" VerticalAlignment="Bottom" Background="Transparent" BorderBrush="Transparent" Padding="0" Click="TabScrollRightButton_OnClick" ToolTip="Scroll tabs right">
                                <Border x:Name="TabScrollRightSurface" Width="28" Height="28" CornerRadius="8" Background="{DynamicResource TabInactiveBrush}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                                </Border>
                            </Button>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource ChromeButtonStyle}" Click="MinimizeButton_OnClick" ToolTip="Minimize">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                                </Button>
                                <Button x:Name="MaxRestoreButton" Style="{StaticResource ChromeButtonStyle}" Click="MaxRestoreButton_OnClick" ToolTip="Maximize/Restore">
                                    <TextBlock x:Name="MaxRestoreIcon" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                                </Button>
                                <Button Style="{StaticResource CloseButtonStyle}" Click="CloseWindowButton_OnClick" ToolTip="Close">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Border x:Name="ClassicMenuRow" Height="36" Background="{DynamicResource MenuBrush}">
                            <Grid Margin="8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="FileMenuButton" Style="{StaticResource MenuTriggerButtonStyle}" Content="File" Click="FileMenuButton_OnClick" />
                                    <Button x:Name="EditMenuButton" Style="{StaticResource MenuTriggerButtonStyle}" Content="Edit" Click="EditMenuButton_OnClick" />
                                    <Button x:Name="ViewMenuButton" Style="{StaticResource MenuTriggerButtonStyle}" Content="View" Click="ViewMenuButton_OnClick" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button x:Name="MarkdownPreviewToolbarButton" Style="{StaticResource MenuTriggerButtonStyle}" Padding="10,4" Content="Markdown preview" Click="MarkdownPreviewMenuItem_OnClick" ToolTip="Toggle markdown preview" Visibility="Collapsed" />
                                    <Button Style="{StaticResource MenuTriggerButtonStyle}" FontFamily="Segoe Fluent Icons" FontSize="14" Padding="8,4" Content="" Click="ThemeToggleToolbarButton_OnClick" ToolTip="Open settings" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Grid x:Name="Windows11MenuRow" Height="34" Margin="6,0,6,6" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="FileMenuButtonWindows11" Style="{StaticResource MenuTriggerButtonStyle}" Content="File" Click="FileMenuButton_OnClick" />
                                <Button x:Name="EditMenuButtonWindows11" Style="{StaticResource MenuTriggerButtonStyle}" Content="Edit" Click="EditMenuButton_OnClick" />
                                <Button x:Name="ViewMenuButtonWindows11" Style="{StaticResource MenuTriggerButtonStyle}" Content="View" Click="ViewMenuButton_OnClick" />
                            </StackPanel>
                            <StackPanel x:Name="MarkdownToolbar" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                                <Button x:Name="HeadingButton" Style="{StaticResource Windows11ToolbarButtonStyle}" Click="HeadingButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="H1" FontSize="13" />
                                        <TextBlock Margin="5,0,0,0" FontFamily="Segoe Fluent Icons" FontSize="9" Text="" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ListButton" Style="{StaticResource Windows11ToolbarButtonStyle}" Click="ListButton_OnClick" ToolTip="List options">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12" Text="" />
                                        <TextBlock Margin="5,0,0,0" FontFamily="Segoe Fluent Icons" FontSize="9" Text="" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource Windows11ToolbarIconButtonStyle}" Click="BoldButton_OnClick" ToolTip="Bold">
                                    <TextBlock FontWeight="Bold" Text="B" />
                                </Button>
                                <Button Style="{StaticResource Windows11ToolbarIconButtonStyle}" Click="ItalicButton_OnClick" ToolTip="Italic">
                                    <TextBlock FontStyle="Italic" Text="I" />
                                </Button>
                                <Button Style="{StaticResource Windows11ToolbarIconButtonStyle}" Click="StrikeButton_OnClick" ToolTip="Strikethrough">
                                    <TextBlock TextDecorations="Strikethrough" Text="S" />
                                </Button>
                                <Button Style="{StaticResource Windows11ToolbarIconButtonStyle}" Click="LinkButton_OnClick" ToolTip="Insert link">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12" Text="" />
                                </Button>
                                <Button Style="{StaticResource Windows11ToolbarIconButtonStyle}" Click="TableButton_OnClick" ToolTip="Table">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12" Text="" />
                                </Button>
                                <Button x:Name="Windows11MarkdownPreviewToolbarButton" Style="{StaticResource Windows11ToolbarButtonStyle}" Padding="10,0" Click="MarkdownPreviewMenuItem_OnClick" ToolTip="Toggle markdown preview">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12" Text="" />
                                        <TextBlock x:Name="Windows11MarkdownPreviewText" Margin="6,0,0,0" Text="Preview" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource Windows11ToolbarIconButtonStyle}" Click="SettingsMenuItem_OnClick" ToolTip="Settings">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12" Text="" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border x:Name="StatusChrome" DockPanel.Dock="Bottom" Background="{DynamicResource StatusBrush}">
                    <Grid Height="26" Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock x:Name="CaretText" Style="{StaticResource StatusTextStyle}" Text="Ln 1, Col 1" />
                            <Border Width="1" Height="14" Margin="14,0" Background="{DynamicResource DividerBrush}" Opacity="0.5" VerticalAlignment="Center" />
                            <TextBlock x:Name="SelectionText" Style="{StaticResource StatusTextStyle}" Visibility="Collapsed" />
                            <Border x:Name="SelectionDivider" Width="1" Height="14" Margin="14,0" Background="{DynamicResource DividerBrush}" Opacity="0.5" VerticalAlignment="Center" Visibility="Collapsed" />
                            <TextBlock x:Name="CharacterCountText" Style="{StaticResource StatusTextStyle}" Text="0 characters" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="ZoomText" Style="{StaticResource StatusTextStyle}" Text="100%" />
                            <Border Width="1" Height="14" Margin="14,0" Background="{DynamicResource DividerBrush}" Opacity="0.5" VerticalAlignment="Center" />
                            <TextBlock x:Name="LineEndingText" Style="{StaticResource StatusTextStyle}" Text="Windows (CRLF)" />
                            <Border Width="1" Height="14" Margin="14,0" Background="{DynamicResource DividerBrush}" Opacity="0.5" VerticalAlignment="Center" />
                            <TextBlock x:Name="EncodingText" Style="{StaticResource StatusTextStyle}" Text="UTF-8" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Background="{DynamicResource EditorBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <WebBrowser x:Name="MarkdownPreviewBrowser" Visibility="Collapsed" />
                        <avalonedit:TextEditor
                            x:Name="EditorTextBox"
                            Background="{DynamicResource EditorBackgroundBrush}"
                            Foreground="{DynamicResource EditorForegroundBrush}"
                            BorderThickness="0"
                            Padding="14,10"
                            FontFamily="{StaticResource EditorFont}"
                            FontSize="14"
                            ShowLineNumbers="False"
                            WordWrap="False"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                        />
                        <Border x:Name="StreamingBadge" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,18,0" Padding="10,4" Background="{DynamicResource AccentSoftBrush}" CornerRadius="12" Visibility="Collapsed">
                            <TextBlock x:Name="LoadingText" Foreground="{DynamicResource AccentBrush}" FontSize="11" Text="Loading…" />
                        </Border>
                    </Grid>
                    <Border x:Name="FindPanel" Grid.Row="1" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,12" Visibility="Collapsed" HorizontalAlignment="Center" Width="860">
                        <StackPanel>
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="FindExpandButton" Style="{StaticResource Windows11ToolbarIconButtonStyle}" Width="28" Height="28" Margin="0,0,10,0" Click="FindPanelOptionsButton_OnClick" ToolTip="Show replace">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="10" Text="" />
                                </Button>
                                <Grid Grid.Column="1" Margin="12,0,0,0">
                                    <TextBox x:Name="FindTextBox" Style="{StaticResource FindTextBoxStyle}" TextChanged="FindTextBox_OnTextChanged" KeyDown="FindTextBox_OnKeyDown" AcceptsReturn="False" />
                                    <TextBlock x:Name="MatchCountText" Foreground="{DynamicResource EditorMutedBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,30,0" IsHitTestVisible="False" Visibility="Collapsed" />
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource EditorMutedBrush}" Text="" />
                                </Grid>
                                <Button x:Name="FindOptionsButton" Grid.Column="2" Style="{StaticResource Windows11ToolbarIconButtonStyle}" Width="28" Height="28" Margin="12,0,0,0" Click="FindPanelMoreOptionsButton_OnClick" ToolTip="Search options">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="13" Text="" />
                                </Button>
                                <Button Grid.Column="3" Style="{StaticResource Windows11ToolbarIconButtonStyle}" Width="28" Height="28" Margin="8,0,0,0" Focusable="False" Click="CloseFindPanelButton_OnClick" ToolTip="Close (Escape)">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="11" Text="" />
                                </Button>
                            </Grid>
                            <Grid x:Name="ReplaceRowPanel" VerticalAlignment="Center" Margin="0,8,0,0" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" />
                                <TextBox x:Name="ReplaceTextBox" Grid.Column="1" Style="{StaticResource FindTextBoxStyle}" Margin="12,0,0,0" />
                                <Button Grid.Column="2" Style="{StaticResource FindActionButtonStyle}" Content="Replace" Focusable="False" Margin="12,0,0,0" Click="ReplaceOneButton_OnClick" />
                                <Button Grid.Column="3" Style="{StaticResource FindActionButtonStyle}" Content="Replace all" Focusable="False" Margin="8,0,0,0" Click="ReplaceAllButton_OnClick" />
                            </Grid>
                            <StackPanel x:Name="FindOptionsRow" Orientation="Horizontal" Margin="38,8,0,0" Visibility="Collapsed">
                                <CheckBox x:Name="MatchCaseCheckBox" Content="Match case" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" VerticalAlignment="Center" Focusable="False" />
                                <CheckBox x:Name="WholeWordCheckBox" Content="Whole word" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" VerticalAlignment="Center" Focusable="False" Margin="12,0,0,0" />
                                <CheckBox x:Name="UseRegexCheckBox" Content="Regex" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" VerticalAlignment="Center" Focusable="False" Margin="12,0,0,0" />
                                <CheckBox x:Name="HighlightAllCheckBox" Content="Highlight all" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" VerticalAlignment="Center" Focusable="False" Margin="12,0,0,0" Checked="HighlightAllCheckBox_OnChecked" Unchecked="HighlightAllCheckBox_OnUnchecked" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
        <Popup x:Name="FileMenuPopup" PlacementTarget="{Binding ElementName=FileMenuButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Style="{StaticResource PopupBorderStyle}" Width="248">
                <StackPanel>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="NewFileMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="New tab" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+N" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="NewWindowMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="New window" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Shift+N" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="NewMarkdownMenuItem_OnClick">
                        <TextBlock Text="New Markdown tab" />
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="OpenButton_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Open" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+O" />
                        </Grid>
                    </Button>
                    <Expander x:Name="RecentFilesExpander" Header="Recent" Margin="8,2" Background="Transparent" Foreground="{DynamicResource MenuForegroundBrush}">
                        <StackPanel x:Name="RecentFilesPanel" Margin="0,4,0,4" />
                    </Expander>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="ReloadButton_OnClick">
                        <TextBlock Text="Reload from disk" />
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="SaveMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Save" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+S" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="SaveAsMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Save as" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Shift+S" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="SaveWithEncodingMenuItem_OnClick">
                        <TextBlock Text="Save with encoding" />
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="SaveAllMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Save all" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Alt+S" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="PageSetupMenuItem_OnClick">
                        <TextBlock Text="Page setup" />
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="PrintMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Print" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+P" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="CloseTabMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Close tab" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+W" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="CloseWindowMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Close window" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Shift+W" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="ExitMenuItem_OnClick">
                        <TextBlock Text="Exit" />
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
        <Popup x:Name="EditMenuPopup" PlacementTarget="{Binding ElementName=EditMenuButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Style="{StaticResource PopupBorderStyle}" Width="250">
                <StackPanel>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="UndoMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Undo" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Z" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="RedoMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Redo" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Y" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="CutMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cut" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+X" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="CopyMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Copy" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+C" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="PasteMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Paste" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+V" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="DeleteMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Delete" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Del" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="ClearFormattingMenuItem_OnClick">
                        <TextBlock Text="Clear formatting" />
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="SearchWithBingMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Search with Bing" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+E" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="FindButton_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Find" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+F" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="FindNextMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Find next" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="F3" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="FindPreviousMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Find previous" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Shift+F3" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="FindAndReplaceButton_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Replace" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+H" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="GoToMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Go to" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+G" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="SelectAllMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Select all" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+A" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="InsertTimeDateButton_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Time/Date" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="F5" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="FontMenuItem_OnClick">
                        <TextBlock Text="Font" />
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
        <Popup x:Name="ViewMenuPopup" PlacementTarget="{Binding ElementName=ViewMenuButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Style="{StaticResource PopupBorderStyle}" Width="240">
                <StackPanel>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="ZoomInMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Zoom in" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl++" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="ZoomOutMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Zoom out" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+-" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="RestoreZoomMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Restore default zoom" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+0" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="WordWrapMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="WordWrapCheckGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Word wrap" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="StatusBarMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="StatusBarCheckGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0.85" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Status bar" />
                        </Grid>
                    </Button>
                    <Button x:Name="MarkdownPreviewMenuItem" Style="{StaticResource PopupRowButtonStyle}" Click="MarkdownPreviewMenuItem_OnClick" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="MarkdownPreviewGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Markdown preview" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="LightThemeMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LightThemeGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Light theme" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="DarkThemeMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DarkThemeGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0.85" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Dark theme" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
        <Popup x:Name="HeadingMenuPopup" PlacementTarget="{Binding ElementName=HeadingButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Style="{StaticResource PopupBorderStyle}" Width="178">
                <StackPanel>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="# " Click="HeadingLevelMenuItem_OnClick"><TextBlock FontSize="26" Text="Title" /></Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="## " Click="HeadingLevelMenuItem_OnClick"><TextBlock FontSize="18" Text="Subtitle" /></Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="### " Click="HeadingLevelMenuItem_OnClick"><TextBlock FontSize="16" Text="Heading" /></Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="#### " Click="HeadingLevelMenuItem_OnClick"><TextBlock FontSize="14" Text="Subheading" /></Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="##### " Click="HeadingLevelMenuItem_OnClick"><TextBlock FontSize="13" Text="Section" /></Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="###### " Click="HeadingLevelMenuItem_OnClick"><TextBlock FontSize="12" Text="Subsection" /></Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="" Click="HeadingLevelMenuItem_OnClick"><TextBlock FontSize="12" Text="Body" /></Button>
                </StackPanel>
            </Border>
        </Popup>
        <Popup x:Name="ListMenuPopup" PlacementTarget="{Binding ElementName=ListButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Style="{StaticResource PopupBorderStyle}" Width="178">
                <StackPanel>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="bullet" Click="ListMenuItem_OnClick"><TextBlock Text="Bulleted list" /></Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="number" Click="ListMenuItem_OnClick"><TextBlock Text="Numbered list" /></Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="indent-more" Click="ListMenuItem_OnClick"><TextBlock Text="Increase indent" /></Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Tag="indent-less" Click="ListMenuItem_OnClick"><TextBlock Text="Decrease indent" /></Button>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
