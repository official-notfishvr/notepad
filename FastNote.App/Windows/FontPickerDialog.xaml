<Window
    x:Class="FastNote.App.FontPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Font"
    Width="520"
    Height="420"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Background="{DynamicResource WindowBackgroundBrush}"
    Foreground="{DynamicResource MenuForegroundBrush}"
    FontFamily="{DynamicResource EditorFont}"
    Icon="pack://application:,,,/Assets/txtfile.ico">
    <Border Margin="14" Style="{StaticResource DialogSectionBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <ListBox x:Name="FontList" Margin="0,0,6,0" FontSize="12" Style="{StaticResource DialogListBoxStyle}" />
                <ListBox x:Name="StyleList" Grid.Column="1" Margin="0,0,6,0" FontSize="12" Style="{StaticResource DialogListBoxStyle}" />
                <ListBox x:Name="SizeList" Grid.Column="2" FontSize="12" Style="{StaticResource DialogListBoxStyle}" />
            </Grid>

            <TextBlock
                x:Name="PreviewText"
                Grid.Row="1"
                Margin="0,10,0,10"
                FontSize="14"
                TextWrapping="Wrap"
                Foreground="{DynamicResource MenuForegroundBrush}"
                Text="AaBbCcDdEe 0123456789" />

            <StackPanel Grid.Row="2" Margin="0,6,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="72" Height="30" Margin="0,0,8,0" IsDefault="True" Style="{StaticResource DialogPrimaryButtonStyle}" Content="OK" Click="OkButton_OnClick" />
                <Button Width="72" Height="30" IsCancel="True" Style="{StaticResource DialogButtonStyle}" Content="Cancel" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
