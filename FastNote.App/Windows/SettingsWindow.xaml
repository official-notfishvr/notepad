<Window
    x:Class="FastNote.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    Width="560"
    Height="520"
    MinWidth="560"
    MinHeight="520"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Background="{DynamicResource WindowBackgroundBrush}"
    FontFamily="{DynamicResource UiFont}"
    Icon="pack://application:,,,/Assets/txtfile.ico">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18" MouseLeftButtonDown="HeaderRegion_OnMouseLeftButtonDown">
            <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MenuForegroundBrush}" Text="FastNote Settings" />
            <TextBlock
                Margin="0,8,0,0"
                Foreground="{DynamicResource EditorMutedBrush}"
                Text="Theme, editor defaults, and file opening are managed here." />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="0,0,0,14"
                Padding="18"
                Background="{DynamicResource PopupBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock Margin="0,0,0,12" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MenuForegroundBrush}" Text="Appearance" />
                    <TextBlock Margin="0,0,0,6" FontSize="12" Foreground="{DynamicResource EditorMutedBrush}" Text="Theme" />
                    <ComboBox
                        x:Name="ThemeComboBox"
                        Height="32"
                        Margin="0,0,0,14"
                        Background="{DynamicResource InputBackgroundBrush}"
                        Foreground="{DynamicResource EditorForegroundBrush}"
                        BorderBrush="{DynamicResource InputBorderBrush}">
                        <ComboBoxItem Content="Dark" />
                        <ComboBoxItem Content="Light" />
                    </ComboBox>
                    <CheckBox x:Name="StatusBarCheckBox" Margin="0,0,0,10" Foreground="{DynamicResource MenuForegroundBrush}" Content="Show status bar" />
                    <CheckBox x:Name="WordWrapCheckBox" Foreground="{DynamicResource MenuForegroundBrush}" Content="Use word wrap for new documents" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="1"
                Padding="18"
                Background="{DynamicResource PopupBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Margin="0,0,0,8" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MenuForegroundBrush}" Text="File Opening" />
                        <TextBlock
                            x:Name="AssociationDescriptionText"
                            Margin="0,0,0,6"
                            TextWrapping="Wrap"
                            Foreground="{DynamicResource MenuForegroundBrush}" />
                        <TextBlock
                            x:Name="AssociationPathText"
                            FontSize="11"
                            TextWrapping="Wrap"
                            Foreground="{DynamicResource EditorMutedBrush}" />
                        <TextBlock
                            x:Name="AssociationExtensionsText"
                            Margin="0,10,0,0"
                            FontSize="11"
                            TextWrapping="Wrap"
                            Foreground="{DynamicResource EditorMutedBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button
                            x:Name="InstallAssociationButton"
                            Width="136"
                            Height="34"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Foreground="{DynamicResource MenuForegroundBrush}"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            Content="Set as default"
                            Click="InstallAssociationButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,18,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button
                Width="84"
                Height="30"
                Margin="0,0,8,0"
                IsDefault="True"
                Background="{DynamicResource InputBackgroundBrush}"
                Foreground="{DynamicResource MenuForegroundBrush}"
                BorderBrush="{DynamicResource InputBorderBrush}"
                Content="Save"
                Click="SaveButton_OnClick" />
            <Button
                Width="84"
                Height="30"
                IsCancel="True"
                Background="{DynamicResource InputBackgroundBrush}"
                Foreground="{DynamicResource MenuForegroundBrush}"
                BorderBrush="{DynamicResource InputBorderBrush}"
                Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>
