<Window
    x:Class="FastNote.App.FontPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Font"
    Width="520"
    Height="420"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Background="{DynamicResource PopupBackgroundBrush}"
    Icon="pack://application:,,,/Assets/txtfile.ico">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="FontList" Margin="0,0,6,0" FontSize="12" />
            <ListBox x:Name="StyleList" Grid.Column="1" Margin="0,0,6,0" FontSize="12" />
            <ListBox x:Name="SizeList" Grid.Column="2" FontSize="12" />
        </Grid>

        <TextBlock
            x:Name="PreviewText"
            Grid.Row="1"
            Margin="0,10,0,10"
            FontSize="14"
            TextWrapping="Wrap"
            Foreground="{DynamicResource MenuForegroundBrush}"
            Text="AaBbCcDdEe 0123456789" />

        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,6,0,0">
            <Button Width="72" Height="28" Margin="0,0,8,0" IsDefault="True" Content="OK" Click="OkButton_OnClick" />
            <Button Width="72" Height="28" IsCancel="True" Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>
