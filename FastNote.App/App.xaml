<Application x:Class="FastNote.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <FontFamily x:Key="UiFont">Segoe UI Variable Text</FontFamily>
        <FontFamily x:Key="EditorFont">Consolas</FontFamily>

        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF3F3F3" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#FFF7F7F7" />
        <SolidColorBrush x:Key="MenuBrush" Color="#FFF8F8F8" />
        <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="EditorForegroundBrush" Color="#FF1F1F1F" />
        <SolidColorBrush x:Key="EditorMutedBrush" Color="#FF696969" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFE1E1E1" />
        <SolidColorBrush x:Key="TabActiveBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="TabInactiveBrush" Color="#00FFFFFF" />
        <SolidColorBrush x:Key="TabForegroundBrush" Color="#FF1F1F1F" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF0078D4" />
        <SolidColorBrush x:Key="StatusBrush" Color="#FFF8F8F8" />
        <SolidColorBrush x:Key="StatusForegroundBrush" Color="#FF4A4A4A" />
        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#FF1F1F1F" />
        <SolidColorBrush x:Key="MenuSelectionBrush" Color="#FFEAEAEA" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource EditorForegroundBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="{DynamicResource MenuBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}" />
            <Setter Property="Padding" Value="10,4" />
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{DynamicResource StatusBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource StatusForegroundBrush}" />
        </Style>
    </Application.Resources>
</Application>
