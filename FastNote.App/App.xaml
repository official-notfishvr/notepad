<Application x:Class="FastNote.App.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <FontFamily x:Key="UiFont">Segoe UI Variable Text</FontFamily>
        <FontFamily x:Key="EditorFont">Consolas</FontFamily>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF202020" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#FF2C2C2C" />
        <SolidColorBrush x:Key="MenuBrush" Color="#FF2C2C2C" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FF2C2C2C" />
        <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#FF383838" />
        <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#FF1F1F1F" />
        <SolidColorBrush x:Key="EditorForegroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="EditorMutedBrush" Color="#FF9D9D9D" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FF383838" />
        <SolidColorBrush x:Key="DividerBrush" Color="#FF404040" />
        <SolidColorBrush x:Key="TabActiveBrush" Color="#FF1F1F1F" />
        <SolidColorBrush x:Key="TabInactiveBrush" Color="#00000000" />
        <SolidColorBrush x:Key="TabHoverBrush" Color="#FF2D2D2D" />
        <SolidColorBrush x:Key="TabForegroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF60CDFF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#2260CDFF" />
        <SolidColorBrush x:Key="StatusBrush" Color="#FF2C2C2C" />
        <SolidColorBrush x:Key="StatusForegroundBrush" Color="#FFB4B4B4" />
        <SolidColorBrush x:Key="MenuForegroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="MenuSelectionBrush" Color="#FF3D3D3D" />
        <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FF2C2C2C" />
        <SolidColorBrush x:Key="PopupBorderBrush" Color="#FF454545" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FF383838" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#FF5A5A5A" />
        <SolidColorBrush x:Key="InputFocusBrush" Color="#FF60CDFF" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF3D3D3D" />
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF484848" />
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#FF686868" />
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#FF888888" />
        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#18FFFFFF" />
        <SolidColorBrush x:Key="FindHighlightBrush" Color="#FF60CDFF" />
        <SolidColorBrush x:Key="FindHighlightForegroundBrush" Color="#FF000000" />
        <Style TargetType="Window">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource EditorForegroundBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource EditorForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource EditorForegroundBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentSoftBrush}" />
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="{DynamicResource ScrollTrackBrush}" />
        </Style>
        <Style TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource ScrollThumbBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbRoot" Margin="2" Background="{TemplateBinding Background}" CornerRadius="6" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
