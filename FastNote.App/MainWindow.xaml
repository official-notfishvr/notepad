<Window
    x:Class="FastNote.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    mc:Ignorable="d"
    Title="Untitled - Notepad"
    Width="1100"
    Height="700"
    MinWidth="480"
    MinHeight="320"
    WindowStyle="None"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    AllowDrop="True"
    Drop="Window_OnDrop"
    DragOver="Window_OnDragOver"
    StateChanged="Window_OnStateChanged"
>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource WindowBackgroundBrush}">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top" Background="{DynamicResource ChromeBrush}">
                    <StackPanel>
                        <Grid x:Name="TitleBar" Height="38" Background="Transparent" PreviewMouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="12,0,8,0" VerticalAlignment="Center" FontFamily="Segoe Fluent Icons" FontSize="15" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" CanContentScroll="False" VerticalAlignment="Bottom" Background="Transparent">
                                <StackPanel x:Name="TabStripPanel" Orientation="Horizontal" />
                            </ScrollViewer>
                            <Button x:Name="NewTabButton" Grid.Column="2" Style="{StaticResource ChromeButtonStyle}" Width="28" Height="28" Margin="6,0,0,0" Click="NewTabButton_OnClick" ToolTip="New tab (Ctrl+N)">
                                <TextBlock FontFamily="Segoe Fluent Icons" FontSize="11" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                            </Button>
                            <Border Grid.Column="3" Background="Transparent" />
                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource ChromeButtonStyle}" Click="MinimizeButton_OnClick" ToolTip="Minimize">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                                </Button>
                                <Button x:Name="MaxRestoreButton" Style="{StaticResource ChromeButtonStyle}" Click="MaxRestoreButton_OnClick" ToolTip="Maximize/Restore">
                                    <TextBlock x:Name="MaxRestoreIcon" FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                                </Button>
                                <Button Style="{StaticResource CloseButtonStyle}" Click="CloseWindowButton_OnClick" ToolTip="Close">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="10" Foreground="{DynamicResource MenuForegroundBrush}" Text="" />
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Border Height="36" Background="{DynamicResource MenuBrush}">
                            <Grid Margin="8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="FileMenuButton" Style="{StaticResource MenuTriggerButtonStyle}" Content="File" Click="FileMenuButton_OnClick" />
                                    <Button x:Name="EditMenuButton" Style="{StaticResource MenuTriggerButtonStyle}" Content="Edit" Click="EditMenuButton_OnClick" />
                                    <Button x:Name="ViewMenuButton" Style="{StaticResource MenuTriggerButtonStyle}" Content="View" Click="ViewMenuButton_OnClick" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button x:Name="MarkdownPreviewToolbarButton" Style="{StaticResource MenuTriggerButtonStyle}" Padding="10,4" Content="Markdown preview" Click="MarkdownPreviewMenuItem_OnClick" ToolTip="Toggle markdown preview" Visibility="Collapsed" />
                                    <Button Style="{StaticResource MenuTriggerButtonStyle}" FontFamily="Segoe Fluent Icons" FontSize="14" Padding="8,4" Content="" Click="ThemeToggleToolbarButton_OnClick" ToolTip="Open settings" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
                <Border x:Name="StatusChrome" DockPanel.Dock="Bottom" Background="{DynamicResource StatusBrush}">
                    <StackPanel Orientation="Horizontal" Height="26" Margin="12,0">
                        <TextBlock x:Name="CaretText" Style="{StaticResource StatusTextStyle}" Text="Ln 1, Col 1" />
                        <Border Width="1" Height="14" Margin="14,0" Background="{DynamicResource DividerBrush}" Opacity="0.5" VerticalAlignment="Center" />
                        <TextBlock x:Name="SelectionText" Style="{StaticResource StatusTextStyle}" Visibility="Collapsed" />
                        <Border x:Name="SelectionDivider" Width="1" Height="14" Margin="14,0" Background="{DynamicResource DividerBrush}" Opacity="0.5" VerticalAlignment="Center" Visibility="Collapsed" />
                        <TextBlock x:Name="ZoomText" Style="{StaticResource StatusTextStyle}" Text="100%" />
                        <Border Width="1" Height="14" Margin="14,0" Background="{DynamicResource DividerBrush}" Opacity="0.5" VerticalAlignment="Center" />
                        <TextBlock x:Name="LineEndingText" Style="{StaticResource StatusTextStyle}" Text="Windows (CRLF)" />
                        <Border Width="1" Height="14" Margin="14,0" Background="{DynamicResource DividerBrush}" Opacity="0.5" VerticalAlignment="Center" />
                        <TextBlock x:Name="EncodingText" Style="{StaticResource StatusTextStyle}" Text="UTF-8" />
                    </StackPanel>
                </Border>
                <Grid Background="{DynamicResource EditorBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <WebBrowser x:Name="MarkdownPreviewBrowser" Visibility="Collapsed" />
                        <avalonedit:TextEditor
                            x:Name="EditorTextBox"
                            Background="{DynamicResource EditorBackgroundBrush}"
                            Foreground="{DynamicResource EditorForegroundBrush}"
                            BorderThickness="0"
                            Padding="14,10"
                            FontFamily="{StaticResource EditorFont}"
                            FontSize="14"
                            ShowLineNumbers="False"
                            WordWrap="False"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                        />
                        <Border x:Name="StreamingBadge" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,18,0" Padding="10,4" Background="{DynamicResource AccentSoftBrush}" CornerRadius="12" Visibility="Collapsed">
                            <TextBlock x:Name="LoadingText" Foreground="{DynamicResource AccentBrush}" FontSize="11" Text="Loading…" />
                        </Border>
                    </Grid>
                    <Border x:Name="FindPanel" Grid.Row="1" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Find" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" VerticalAlignment="Center" Width="56" />
                                <Grid>
                                    <TextBox x:Name="FindTextBox" Style="{StaticResource FindTextBoxStyle}" Width="260" TextChanged="FindTextBox_OnTextChanged" KeyDown="FindTextBox_OnKeyDown" AcceptsReturn="False" />
                                    <TextBlock x:Name="MatchCountText" Foreground="{DynamicResource EditorMutedBrush}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0" IsHitTestVisible="False" Visibility="Collapsed" />
                                </Grid>
                                <Button Style="{StaticResource FindActionButtonStyle}" Width="32" Padding="0" Margin="4,0,0,0" Click="FindPreviousButton_OnClick" ToolTip="Previous (Shift+F3)">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="13" Text="" />
                                </Button>
                                <Button Style="{StaticResource FindActionButtonStyle}" Width="32" Padding="0" Margin="3,0,0,0" Click="FindNextButton_OnClick" ToolTip="Next (F3)">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="13" Text="" />
                                </Button>
                                <CheckBox x:Name="MatchCaseCheckBox" Content="Match case" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" VerticalAlignment="Center" Focusable="False" Margin="12,0,0,0" />
                                <CheckBox x:Name="WholeWordCheckBox" Content="Whole word" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" VerticalAlignment="Center" Focusable="False" Margin="10,0,0,0" />
                                <CheckBox x:Name="UseRegexCheckBox" Content="Regex" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" VerticalAlignment="Center" Focusable="False" Margin="10,0,0,0" />
                                <CheckBox
                                    x:Name="HighlightAllCheckBox"
                                    Content="Highlight all"
                                    Foreground="{DynamicResource MenuForegroundBrush}"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Focusable="False"
                                    Margin="10,0,0,0"
                                    Checked="HighlightAllCheckBox_OnChecked"
                                    Unchecked="HighlightAllCheckBox_OnUnchecked"
                                />
                                <Button Style="{StaticResource FindActionButtonStyle}" Width="32" Padding="0" Margin="14,0,0,0" Focusable="False" Click="CloseFindPanelButton_OnClick" ToolTip="Close (Escape)">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="11" Text="" />
                                </Button>
                            </StackPanel>
                            <StackPanel x:Name="ReplaceRowPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,0,0" Visibility="Collapsed">
                                <TextBlock Text="Replace" Foreground="{DynamicResource MenuForegroundBrush}" FontSize="12" VerticalAlignment="Center" Width="56" />
                                <TextBox x:Name="ReplaceTextBox" Style="{StaticResource FindTextBoxStyle}" Width="260" />
                                <Button Style="{StaticResource FindActionButtonStyle}" Content="Replace" Focusable="False" Margin="4,0,0,0" Click="ReplaceOneButton_OnClick" />
                                <Button Style="{StaticResource FindActionButtonStyle}" Content="Replace all" Focusable="False" Margin="4,0,0,0" Click="ReplaceAllButton_OnClick" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
        <Popup x:Name="FileMenuPopup" PlacementTarget="{Binding ElementName=FileMenuButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Style="{StaticResource PopupBorderStyle}" Width="230">
                <StackPanel>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="NewFileMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="New" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+N" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="NewWindowMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="New window" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Shift+N" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="OpenButton_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Open…" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+O" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="ReloadButton_OnClick">
                        <TextBlock Text="Reload from disk" />
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="SaveMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Save" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+S" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="SaveAsMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Save as…" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Shift+S" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="PageSetupMenuItem_OnClick">
                        <TextBlock Text="Page setup…" />
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="PrintMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Print…" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+P" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="ExitMenuItem_OnClick">
                        <TextBlock Text="Exit" />
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
        <Popup x:Name="EditMenuPopup" PlacementTarget="{Binding ElementName=EditMenuButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Style="{StaticResource PopupBorderStyle}" Width="250">
                <StackPanel>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="UndoMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Undo" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Z" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="RedoMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Redo" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+Y" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="CutMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cut" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+X" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="CopyMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Copy" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+C" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="PasteMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Paste" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+V" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="FindButton_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Find…" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+F" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="FindAndReplaceButton_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Find and replace…" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+H" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="GoToMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Go to line…" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+G" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="SelectAllMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Select all" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+A" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="InsertTimeDateButton_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Time/Date" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="F5" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="FontMenuItem_OnClick">
                        <TextBlock Text="Font…" />
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
        <Popup x:Name="ViewMenuPopup" PlacementTarget="{Binding ElementName=ViewMenuButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Style="{StaticResource PopupBorderStyle}" Width="240">
                <StackPanel>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="ZoomInMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Zoom in" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl++" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="ZoomOutMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Zoom out" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+-" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="RestoreZoomMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Restore default zoom" />
                            <TextBlock Grid.Column="1" Opacity="0.5" Text="Ctrl+0" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="WordWrapMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="WordWrapCheckGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Word wrap" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="StatusBarMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="StatusBarCheckGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0.85" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Status bar" />
                        </Grid>
                    </Button>
                    <Button x:Name="MarkdownPreviewMenuItem" Style="{StaticResource PopupRowButtonStyle}" Click="MarkdownPreviewMenuItem_OnClick" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="MarkdownPreviewGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Markdown preview" />
                        </Grid>
                    </Button>
                    <Border Height="1" Margin="8,2" Background="{DynamicResource PopupBorderBrush}" />
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="LightThemeMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LightThemeGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Light theme" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource PopupRowButtonStyle}" Click="DarkThemeMenuItem_OnClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DarkThemeGlyph" FontFamily="Segoe Fluent Icons" FontSize="12" Text="" Opacity="0.85" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Dark theme" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
