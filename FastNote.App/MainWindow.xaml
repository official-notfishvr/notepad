<Window x:Class="FastNote.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:FastNote.App.Controls"
        mc:Ignorable="d"
        Title="FastNote"
        Height="760"
        Width="1220"
        MinHeight="540"
        MinWidth="840"
        AllowDrop="True"
        Drop="Window_OnDrop"
        DragOver="Window_OnDragOver">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                Margin="0,0,0,14"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26"
                               FontWeight="SemiBold"
                               Text="FastNote" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="Virtualized large-file viewer built for opening multi-million-line text files without materializing the whole document in memory." />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,8"
                        Background="{StaticResource AccentSoftBrush}"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="Large File Mode" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Viewport-only rendering" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="14"
                Margin="0,0,0,14"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="OpenButton_OnClick" Content="Open" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="ReloadButton_OnClick" Content="Reload" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SubtleTextBrush}"
                           Text="Ctrl+O to open" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="16,12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock x:Name="FileNameText"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="No file loaded" />
                                <TextBlock x:Name="FileMetaText"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           Text="Open a text file to start." />
                            </StackPanel>

                            <TextBlock x:Name="LoadBadgeText"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource CodeFont}"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="Idle" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <controls:DocumentViewport x:Name="Viewport"
                                                   Background="#FFFDFEFF"
                                                   Focusable="True"
                                                   TopLineChanged="Viewport_OnTopLineChanged" />

                        <ScrollBar x:Name="VerticalScrollBar"
                                   Grid.Column="1"
                                   Width="18"
                                   Margin="0,6,6,6"
                                   Orientation="Vertical"
                                   Minimum="0"
                                   ValueChanged="VerticalScrollBar_OnValueChanged" />

                        <Border x:Name="LoadingOverlay"
                                Grid.ColumnSpan="2"
                                Background="#D8F6F7FB"
                                CornerRadius="18"
                                Visibility="Collapsed">
                            <StackPanel Width="320"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="LoadingTitleText"
                                           HorizontalAlignment="Center"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Text="Indexing file" />
                                <TextBlock x:Name="LoadingDetailText"
                                           Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           Text="Scanning line breaks and building the viewport index." />
                                <ProgressBar x:Name="LoadingProgressBar"
                                             Height="12"
                                             Margin="0,18,0,0"
                                             Minimum="0"
                                             Maximum="100" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Padding="14,12"
                Margin="0,14,0,0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SubtleTextBrush}"
                           Text="Ready." />
                <TextBlock x:Name="ViewportStatusText"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource CodeFont}"
                           Foreground="{StaticResource SubtleTextBrush}"
                           Text="Line 0 / 0" />
            </Grid>
        </Border>
    </Grid>
</Window>
