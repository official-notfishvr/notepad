<Application x:Class="FastNote.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF6F7FB" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFD7DDE9" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF0F6CBD" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#FFEAF4FF" />
        <SolidColorBrush x:Key="TextBrush" Color="#FF1C2737" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#FF5F6D83" />
        <FontFamily x:Key="UiFont">Segoe UI</FontFamily>
        <FontFamily x:Key="CodeFont">Cascadia Mono</FontFamily>

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Application.Resources>
</Application>
