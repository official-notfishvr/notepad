<Window
    x:Class="FastNote.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    Width="560"
    Height="520"
    MinWidth="560"
    MinHeight="520"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Background="{DynamicResource WindowBackgroundBrush}"
    Foreground="{DynamicResource MenuForegroundBrush}"
    FontFamily="{DynamicResource EditorFont}"
    Icon="pack://application:,,,/Assets/txtfile.ico">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18" MouseLeftButtonDown="HeaderRegion_OnMouseLeftButtonDown">
            <TextBlock Style="{StaticResource DialogTitleTextStyle}" Text="FastNote Settings" />
            <TextBlock Margin="0,8,0,0" Style="{StaticResource DialogBodyTextStyle}" Text="Theme, editor defaults, and file opening are managed here." />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,0,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="0,0,0,14" Style="{StaticResource DialogSectionBorderStyle}">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,12" Style="{StaticResource DialogSectionTitleTextStyle}" Text="Appearance" />
                        <TextBlock Margin="0,0,0,6" Style="{StaticResource DialogLabelTextStyle}" Text="Layout" />
                        <ComboBox x:Name="AppearanceComboBox" Margin="0,0,0,14">
                            <ComboBoxItem Content="Classic" />
                            <ComboBoxItem Content="Windows 11" />
                        </ComboBox>
                        <TextBlock Margin="0,0,0,6" Style="{StaticResource DialogLabelTextStyle}" Text="Theme" />
                        <ComboBox x:Name="ThemeComboBox" Margin="0,0,0,14">
                            <ComboBoxItem Content="Dark" />
                            <ComboBoxItem Content="Light" />
                        </ComboBox>
                        <CheckBox x:Name="StatusBarCheckBox" Margin="0,0,0,10" Style="{StaticResource DialogCheckBoxStyle}" Content="Show status bar" />
                        <CheckBox x:Name="WordWrapCheckBox" Margin="0,0,0,10" Style="{StaticResource DialogCheckBoxStyle}" Content="Use word wrap for new documents" />
                        <CheckBox x:Name="RestoreSessionCheckBox" Style="{StaticResource DialogCheckBoxStyle}" Content="Restore previous tabs and unsaved changes on startup" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource DialogSectionBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Margin="0,0,0,8" Style="{StaticResource DialogSectionTitleTextStyle}" Text="File Opening" />
                            <TextBlock x:Name="AssociationDescriptionText" Margin="0,0,0,6" Foreground="{DynamicResource MenuForegroundBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="AssociationPathText" FontSize="11" Style="{StaticResource DialogBodyTextStyle}" />
                            <TextBlock x:Name="AssociationExtensionsText" Margin="0,10,0,0" FontSize="11" Style="{StaticResource DialogBodyTextStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button
                                x:Name="InstallAssociationButton"
                                Width="136"
                                Height="34"
                                Style="{StaticResource DialogButtonStyle}"
                                Content="Set as default"
                                Click="InstallAssociationButton_OnClick" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,18,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button
                Width="84"
                Margin="0,0,8,0"
                IsDefault="True"
                Style="{StaticResource DialogPrimaryButtonStyle}"
                Content="Save"
                Click="SaveButton_OnClick" />
            <Button
                Width="84"
                IsCancel="True"
                Style="{StaticResource DialogButtonStyle}"
                Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>
